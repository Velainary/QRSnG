<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.qrsng.HomeFragment"
        android:label="Home">

        <action
            android:id="@+id/action_home_to_scan"
            app:destination="@id/scanFragment" />

        <action
            android:id="@+id/action_home_to_generate"
            app:destination="@id/generateFragment" />

        <action
            android:id="@+id/action_home_to_history"
            app:destination="@id/historyFragment" />

        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />

    </fragment>


    <fragment
        android:id="@+id/scanFragment"
        android:name="com.example.qrsng.ScanFragment"
        android:label="Scan"/>

    <fragment
        android:id="@+id/generateFragment"
        android:name="com.example.qrsng.GenerateFragment"
        android:label="Generate QR" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.qrsng.ui.history.HistoryFragment"
        android:label="History" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.qrsng.ui.settings.SettingsFragment"
        android:label="Settings" />

</navigation>
